---
// Fichier : media-finance-crypto/src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const news = await getCollection('news');
const reviews = await getCollection('reviews');
const tutos = await getCollection('tutos');
---
<BaseLayout title="Accueil - Media Finance & Crypto" description="Accueil du média">
  <div class="space-y-12">
    <section>
      <h2 class="text-2xl font-bold mb-4 border-b pb-2 dark:border-slate-700">Dernières Actualités</h2>
      <ul class="space-y-2">
        {news.map(post => (
          <li>
            <a href={`/news/${post.slug}`} class="text-blue-600 hover:underline dark:text-blue-400 font-medium">
              {post.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4 border-b pb-2 dark:border-slate-700">Analyses</h2>
      <ul class="space-y-2">
        {reviews.map(post => (
          <li>
            <a href={`/reviews/${post.slug}`} class="text-blue-600 hover:underline dark:text-blue-400 font-medium">
              {post.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4 border-b pb-2 dark:border-slate-700">Tutoriels</h2>
      <ul class="space-y-2">
        {tutos.map(post => (
          <li>
            <a href={`/tutos/${post.slug}`} class="text-blue-600 hover:underline dark:text-blue-400 font-medium">
              {post.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>