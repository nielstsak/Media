---
// Fichier : media-finance-crypto/src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const news = await getCollection('news');
const reviews = await getCollection('reviews');
const tutos = await getCollection('tutos');
---
<BaseLayout title="Accueil - Media Finance & Crypto" description="Actualités, analyses et tutoriels de l'écosystème web3">
  
  <section class="mb-20 text-center border-4 border-dark bg-accent p-12 shadow-brutal-lg">
    <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tight mb-6 text-dark border-b-4 border-dark pb-4 inline-block">
      Terminal <span class="bg-dark text-accent px-4 py-1">Web3</span>
    </h1>
    <p class="text-xl md:text-2xl font-bold text-dark max-w-3xl mx-auto">
      Analyses quantitatives, sécurisation réseau et actualités.
    </p>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    
    <section class="lg:col-span-2 space-y-12">
      <div>
        <div class="flex items-center justify-between mb-8 border-b-4 border-dark pb-4">
          <h2 class="text-3xl font-black uppercase">Analyses</h2>
        </div>
        <div class="grid grid-cols-1 gap-8">
          {reviews.map(post => (
            <a href={`/reviews/${post.slug}`} class="block bg-white border-4 border-dark p-6 shadow-brutal hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-brutal-hover transition-all">
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-2xl font-black uppercase text-dark line-clamp-2">{post.data.title}</h3>
                <span class="flex items-center justify-center bg-primary border-2 border-dark text-dark font-black text-xl h-12 w-12 shrink-0 ml-4 shadow-brutal">{post.data.score}</span>
              </div>
              <p class="font-medium text-dark line-clamp-3">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-8 border-b-4 border-dark pb-4">
          <h2 class="text-3xl font-black uppercase">Tutoriels</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {tutos.map(post => (
            <a href={`/tutos/${post.slug}`} class="flex flex-col bg-surface border-4 border-dark p-5 shadow-brutal hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-brutal-hover transition-all">
              <h3 class="text-lg font-black uppercase text-dark mb-4">{post.data.title}</h3>
              <div class="flex flex-wrap gap-3 mt-auto">
                <span class="px-3 py-1 bg-white border-2 border-dark text-dark font-bold text-xs uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">⏱ {post.data.read_time} min</span>
                <span class="px-3 py-1 bg-primary border-2 border-dark text-dark font-bold text-xs uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">{post.data.level}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <aside>
      <div class="sticky top-24 bg-secondary border-4 border-dark p-6 shadow-brutal">
        <h2 class="text-2xl font-black uppercase mb-6 flex items-center gap-3 border-b-4 border-dark pb-4">
          <span class="w-4 h-4 bg-red-500 border-2 border-dark shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] animate-pulse"></span>
          Flux Direct
        </h2>
        <div class="space-y-6">
          {news.map(post => (
            <article class="bg-white border-4 border-dark p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map((tag: string) => (
                  <span class="px-2 py-0.5 bg-dark text-white text-xs font-bold uppercase border border-dark">#{tag}</span>
                ))}
              </div>
              <a href={`/news/${post.slug}`} class="block text-lg font-black uppercase leading-tight mb-2 hover:bg-primary transition-colors">
                {post.data.title}
              </a>
              <time class="text-sm font-bold text-slate-600">
                {new Date(post.data.date).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' })}
              </time>
            </article>
          ))}
        </div>
      </div>
    </aside>

  </div>
</BaseLayout>