---
// Fichier : media-finance-crypto/src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const news = await getCollection('news');
const reviews = await getCollection('reviews');
const tutos = await getCollection('tutos');
---
<BaseLayout title="Accueil - Media Finance & Crypto" description="Actualités, analyses et tutoriels de l'écosystème web3">
  
  <section class="mb-24 text-center max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6 text-sand leading-tight">
      L'intelligence algorithmique au service du Web3.
    </h1>
    <p class="text-lg md:text-xl font-medium text-sand">
      Recherche quantitative, infrastructure réseau et analyses de protocoles.
    </p>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    
    <section class="lg:col-span-2 space-y-16">
      <div>
        <div class="flex items-center justify-between mb-8 border-b border-surface pb-4">
          <h2 class="text-2xl font-bold text-sand tracking-tight">Recherche & Analyses</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {reviews.map(post => (
            <a href={`/reviews/${post.slug}`} class="group flex flex-col bg-surface border border-surface hover:border-accent rounded-xl p-6 transition-all duration-300">
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-xl font-semibold text-sand group-hover:text-sand transition-colors leading-snug">{post.data.title}</h3>
                <span class="flex items-center justify-center bg-deep text-sand font-semibold text-sm h-10 w-10 rounded-full shrink-0 ml-4 border border-accent">{post.data.score}</span>
              </div>
              <p class="font-medium text-sand text-sm line-clamp-3 mt-auto leading-relaxed">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-8 border-b border-surface pb-4">
          <h2 class="text-2xl font-bold text-sand tracking-tight">Ingénierie & Tutoriels</h2>
        </div>
        <div class="grid grid-cols-1 gap-4">
          {tutos.map(post => (
            <a href={`/tutos/${post.slug}`} class="group flex flex-col sm:flex-row sm:items-center justify-between bg-surface border border-surface hover:border-accent rounded-xl p-5 transition-all duration-300">
              <h3 class="text-base font-semibold text-sand transition-colors mb-3 sm:mb-0">{post.data.title}</h3>
              <div class="flex gap-3 shrink-0">
                <span class="px-3 py-1 bg-deep text-sand rounded-lg text-xs font-medium border border-surface whitespace-nowrap">⏱ {post.data.read_time} min</span>
                <span class="px-3 py-1 bg-accent text-deep rounded-lg text-xs font-bold whitespace-nowrap">{post.data.level}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <aside>
      <div class="sticky top-24 bg-surface border border-surface rounded-xl p-6">
        <h2 class="text-lg font-bold text-sand mb-6 flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-sand"></div>
          Flux Réseau
        </h2>
        <div class="space-y-5">
          {news.map(post => (
            <article class="border-b border-deep pb-5 last:border-0 last:pb-0">
              <a href={`/news/${post.slug}`} class="block text-sm font-semibold text-sand leading-snug mb-2 hover:text-accent transition-colors">
                {post.data.title}
              </a>
              <div class="flex items-center justify-between">
                <time class="text-xs font-medium text-sand">
                  {new Date(post.data.date).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' })}
                </time>
                <div class="flex gap-2">
                  {post.data.tags.slice(0, 1).map((tag: string) => (
                    <span class="text-[10px] font-bold text-deep bg-sand px-2 py-0.5 rounded-md">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </aside>

  </div>
</BaseLayout>