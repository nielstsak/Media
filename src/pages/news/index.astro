---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const newsEntries = await getCollection('news');
---
<BaseLayout titreDocument="Actualités" descriptionDocument="Flux d'actualités" typeRoute="news">
  <h1 class="text-h1 font-bold mb-8 text-white">Actualités</h1>
  <div class="flex flex-col gap-4">
    {newsEntries.map(entry => (
      <article class="bg-[#393E46] border border-[#948979] p-4">
        <h2 class="text-h3 font-bold text-[#DFD0B8]">
          <a href={`/news/${entry.slug}`}>{entry.data.title}</a>
        </h2>
      </article>
    ))}
  </div>
</BaseLayout>