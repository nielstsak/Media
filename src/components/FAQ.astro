---
// Fichier : media-finance-crypto/src/components/FAQ.astro
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---
<div class="my-8">
  <h3 class="text-2xl font-bold mb-4">Questions Fréquentes</h3>
  <dl class="space-y-4">
    {items.map((item) => (
      <div class="border-b dark:border-slate-700 pb-4">
        <dt class="font-bold text-lg mb-2">{item.question}</dt>
        <dd class="text-slate-700 dark:text-slate-300 m-0">{item.answer}</dd>
      </div>
    ))}
  </dl>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</div>