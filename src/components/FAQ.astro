---
// Fichier : media-finance-crypto/src/components/FAQ.astro
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---
<div class="my-10 bg-surface border border-surface rounded-xl p-8">
  <h3 class="text-xl font-bold mb-6 text-sand">Questions Fréquentes</h3>
  <dl class="space-y-6">
    {items.map((item) => (
      <div class="border-b border-deep pb-6 last:border-0 last:pb-0">
        <dt class="font-semibold text-sand mb-2">{item.question}</dt>
        <dd class="text-sand font-medium leading-relaxed m-0">{item.answer}</dd>
      </div>
    ))}
  </dl>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</div>