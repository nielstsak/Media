---
// Fichier : media-finance-crypto/src/components/ScoreCard.astro
interface Props {
  score: number;
  pros: string[];
  cons: string[];
}

const { score, pros, cons } = Astro.props;
---
<div class="border rounded-lg p-6 my-6 bg-white dark:bg-slate-800 dark:border-slate-700 shadow-sm">
  <div class="flex items-center justify-between border-b pb-4 mb-4 dark:border-slate-700">
    <h3 class="text-xl font-bold m-0">Évaluation Globale</h3>
    <div class="text-2xl font-black text-blue-600 dark:text-blue-400">{score}/10</div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <h4 class="text-green-600 font-bold mb-2">Points Forts</h4>
      <ul class="list-disc pl-5 m-0 text-slate-700 dark:text-slate-300">
        {pros.map((pro) => <li>{pro}</li>)}
      </ul>
    </div>
    <div>
      <h4 class="text-red-600 font-bold mb-2">Points Faibles</h4>
      <ul class="list-disc pl-5 m-0 text-slate-700 dark:text-slate-300">
        {cons.map((con) => <li>{con}</li>)}
      </ul>
    </div>
  </div>
</div>