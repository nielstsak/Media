---
// Fichier : media-finance-crypto/src/components/ScoreCard.astro
interface Props {
  score: number;
  pros: string[];
  cons: string[];
}

const { score, pros, cons } = Astro.props;
---
<div class="bg-surface border border-surface rounded-xl p-8 my-8">
  <div class="flex items-center justify-between border-b border-deep pb-6 mb-6">
    <h3 class="text-lg font-bold text-sand m-0">Évaluation Globale</h3>
    <div class="flex items-center justify-center w-12 h-12 rounded-full bg-deep border border-accent text-sand font-bold text-xl">{score}</div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div>
      <h4 class="text-sand font-semibold mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Points Forts
      </h4>
      <ul class="space-y-2 m-0 pl-0 list-none">
        {pros.map((pro) => <li class="text-sand font-medium flex items-start gap-2"><span class="text-accent mt-1">•</span>{pro}</li>)}
      </ul>
    </div>
    <div>
      <h4 class="text-sand font-semibold mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg>
        Points Faibles
      </h4>
      <ul class="space-y-2 m-0 pl-0 list-none">
        {cons.map((con) => <li class="text-sand font-medium flex items-start gap-2"><span class="text-accent mt-1">•</span>{con}</li>)}
      </ul>
    </div>
  </div>
</div>