---
// Fichier : media-finance-crypto/src/components/AffiliateBanner.astro
interface Props {
  url: string;
}

const { url } = Astro.props;
---
<div class="my-8 text-center">
  <a 
    href={url} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="inline-block bg-accent text-deep font-bold py-3 px-6 rounded-lg hover:bg-sand transition-colors"
  >
    Découvrir l'offre
  </a>
</div>