---
// Fichier : media-finance-crypto/src/components/ImageZoom.astro
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---
<details class="group my-6 relative cursor-pointer">
  <summary class="list-none">
    <img src={src} alt={alt} class="rounded-lg shadow-md max-w-full h-auto border dark:border-slate-700" />
    <div class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">
      Agrandir
    </div>
  </summary>
  <div class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4 cursor-zoom-out" onclick="this.parentElement.removeAttribute('open')">
    <img src={src} alt={alt} class="max-w-full max-h-[90vh] object-contain rounded" />
  </div>
</details>