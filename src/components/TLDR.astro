---
// Fichier : media-finance-crypto/src/components/TLDR.astro
interface Props {
  points: string[];
}

const { points } = Astro.props;
---
<div class="bg-surface border-l-4 border-accent p-6 rounded-r-xl my-8">
  <h4 class="font-bold text-sm mb-4 uppercase tracking-wider text-sand">Synthèse</h4>
  <ul class="space-y-3 m-0 pl-0 list-none">
    {points.map((point) => (
      <li class="flex items-start gap-3 text-sand font-medium">
        <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>{point}</span>
      </li>
    ))}
  </ul>
</div>