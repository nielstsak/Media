---
// Fichier : media-finance-crypto/src/components/TLDR.astro
interface Props {
  points: string[];
}

const { points } = Astro.props;
---
<div class="bg-slate-100 dark:bg-slate-800 p-5 rounded-lg my-6 shadow-sm border-l-4 border-blue-500">
  <h4 class="font-bold text-lg mb-3 m-0 uppercase tracking-wider text-slate-500 dark:text-slate-400">TL;DR</h4>
  <ul class="list-disc pl-5 m-0 text-slate-800 dark:text-slate-200">
    {points.map((point) => <li>{point}</li>)}
  </ul>
</div>