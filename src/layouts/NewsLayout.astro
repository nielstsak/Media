---
// Fichier : media-finance-crypto/src/layouts/NewsLayout.astro
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---
<BaseLayout title={frontmatter.title} description={`Actualité: ${frontmatter.title}`}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-12 bg-white border-8 border-dark p-8 shadow-brutal-lg">
      <div class="flex flex-wrap gap-4 mb-8">
        {frontmatter.tags.map((tag: string) => (
          <span class="bg-dark text-white px-4 py-2 text-sm font-black uppercase border-4 border-dark">
            #{tag}
          </span>
        ))}
      </div>
      
      <h1 class="text-4xl md:text-6xl font-black mb-8 leading-tight uppercase">{frontmatter.title}</h1>
      
      <div class="flex flex-col sm:flex-row sm:items-center gap-6 text-lg font-black text-dark border-t-8 border-dark pt-6 mt-6">
        <time datetime={frontmatter.date} class="bg-primary px-4 py-2 border-4 border-dark shadow-brutal">
          {new Date(frontmatter.date).toLocaleDateString('fr-FR', { 
            year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'
          })}
        </time>
        <a href={frontmatter.source_link} target="_blank" rel="noopener noreferrer" class="bg-secondary px-4 py-2 border-4 border-dark shadow-brutal hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all">
          Source d'origine
        </a>
      </div>
    </header>

    <div class="prose prose-xl prose-slate max-w-none bg-white border-8 border-dark p-8 md:p-12 shadow-brutal-lg mt-12">
      <slot />
    </div>
  </article>
</BaseLayout>