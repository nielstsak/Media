---
import { SEO } from 'astro-seo';
import { ViewTransitions } from 'astro:transitions';
import Search from '../components/Search.astro';
import SchemaGenerator from '../components/SchemaGenerator.astro';

const { titreDocument, descriptionDocument, typeRoute, donneesFrontmatter } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={titreDocument}
    description={descriptionDocument}
  />
  <ViewTransitions />
  {donneesFrontmatter && <SchemaGenerator typeRoute={typeRoute} donneesFrontmatter={donneesFrontmatter} />}
  <style is:global>
    .svg-noise {
      pointer-events: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      opacity: 0.05;
      mix-blend-mode: overlay;
    }
    
    /* Architecture visuelle et cinétique des cartes */
    .card-interactive {
      background-color: #393E46;
      position: relative;
      overflow: hidden;
      border: 1px solid #948979;
      border-radius: 0.5rem;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
      display: flex;
      flex-direction: column;
    }
    
    .card-interactive:hover {
      transform: scale(1.02);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
      border-color: #DFD0B8;
    }
    
    .card-interactive::before {
      content: "";
      position: absolute;
      inset: 0;
      opacity: 0.15;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.2' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      mix-blend-mode: color-dodge;
      z-index: 0;
    }
    
    .card-interactive > * {
      position: relative;
      z-index: 1;
    }
  </style>
</head>
<body class="bg-[#222831] text-[#DFD0B8] min-h-screen flex flex-col font-sans relative">
  <svg class="svg-noise">
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)"/>
  </svg>

  <header data-pagefind-ignore class="bg-[#393E46] p-6 border-b-4 border-[#948979] flex justify-between items-center relative z-10 transition-colors">
    <nav>
      <ul class="flex gap-6">
        <li><a href="/" class="hover:text-white font-bold uppercase tracking-wider block transition-colors">Accueil</a></li>
        <li><a href="/news" class="hover:text-white font-bold uppercase tracking-wider block transition-colors">Actualités</a></li>
        <li><a href="/reviews" class="hover:text-white font-bold uppercase tracking-wider block transition-colors">Recherche</a></li>
        <li><a href="/tutos" class="hover:text-white font-bold uppercase tracking-wider block transition-colors">Projets et tutoriels</a></li>
      </ul>
    </nav>
    <Search />
  </header>

  <main class="flex-grow p-6 lg:p-12 max-w-6xl mx-auto w-full relative z-10">
    <slot />
  </main>

  <footer data-pagefind-ignore class="bg-[#393E46] p-6 border-t-4 border-[#948979] mt-auto text-center shadow-[-4px_0_10px_rgba(0,0,0,0.5)] relative z-10">
    <p class="text-sm font-bold tracking-widest uppercase">&copy; 2026 Media Finance & Crypto</p>
  </footer>
</body>
</html>