---
import Search from '../components/Search.astro';

// Extraction des métadonnées injectées par les vues enfants lors de la compilation
const { titreDocument, descriptionDocument } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titreDocument}</title>
    <meta name="description" content={descriptionDocument} />
  </head>
  <body class="bg-[#222831] text-[#DFD0B8] min-h-screen flex flex-col font-sans">
    
    <header data-pagefind-ignore class="bg-[#393E46] p-6 border-b-4 border-[#948979] flex justify-between items-center shadow-[4px_4px_0px_0px_#948979]">
      <nav>
        <ul class="flex gap-6">
          <li><a href="/" class="hover:text-white font-bold uppercase tracking-wider">Accueil</a></li>
          <li><a href="/news" class="hover:text-white font-bold uppercase tracking-wider">Actualités</a></li>
          <li><a href="/tutos" class="hover:text-white font-bold uppercase tracking-wider">Tutoriels</a></li>
        </ul>
      </nav>
      
      <Search />
    </header>

    <main class="flex-grow p-6 lg:p-12 max-w-6xl mx-auto w-full">
      <slot />
    </main>

    <footer data-pagefind-ignore class="bg-[#393E46] p-6 border-t-4 border-[#948979] mt-auto text-center shadow-[-4px_-4px_0px_0px_#948979]">
      <p class="text-sm font-bold tracking-widest uppercase">&copy; 2026 Media Finance & Crypto</p>
    </footer>
    
  </body>
</html>